db("sample_mflix").collection("comments").find([
  {
    $lookup: {
      from: "comments",
      localField: "_id",
      foreignField: "movie_id",
      as: "comments"
    }
  },
  {
    $project: {
      title: 1,
      totalComments: { $size: "$comments" },
    },
  },
]);