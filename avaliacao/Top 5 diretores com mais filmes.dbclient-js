// Active: 1775581223186@@db_brian@null@sample_mflix
db("sample_mflix").collection("movies").aggregate([
 {
    $unwind: "$directors"
  },
  {
    $group: {
      _id: "$directors",
      totalFilmes: { $sum: 1 }
    }
  },
  {
    $sort: { totalFilmes: -1 }
  },
  {
    $limit: 5
  }
]);